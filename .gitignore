# Experiment output data
# NOTE: .git/info/exclude used to have blanket rules; they are now consolidated here.
/experiments/*.json
/experiments/*.tsv
/experiments/*.gz
/experiments/*.txt
/experiments/*.log
/experiments/logs/
/experiments/*_part_*.json
# Keep manifest-bound source artifacts trackable.
!/experiments/coupling_analysis.json
!/experiments/final_graph_statistics.json
!/experiments/final_statistics.json

# Generated paper artifacts (figures only; main.pdf is tracked)
paper/figures/*.pdf

# LaTeX build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.synctex.gz

# Zenodo staging (archives for upload, not tracked)
zenodo_staging/

# IDE/editor
.idea/
.vscode/
*.swp
*.swo
out/

